# Vanellix Hub Frontend - .gitignore profesional
/*
!src/

# Dependencias y builds
node_modules/
dist/
build/
dist-ssr/


# Variables de entorno y secretos
.env
*.local

# Archivos temporales y logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tmp
*.temp
*.swp
*.bak
*.old
*.orig

# OS y cachés
.DS_Store
Thumbs.db
.cache/
.vite/

# IDEs y editores
.vscode/
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing y coverage
coverage/
.nyc_output/
*.lcov
*.lcov.info
*.snap

# Documentación generada
storybook-static/
docs/_build/

# Archivos de lock y backups
package-lock.json.backup
yarn.lock.backup
npm-debug.log*
yarn-error.log*

# Otros archivos grandes
*.zip
*.tar.gz
*.tgz
*.7z
*.rar

# Archivos de imágenes optimizadas
*.webp
*.avif

# Archivos multimedia pesados
*.mp4
*.mov
*.avi
*.mkv
*.psd
*.ai
*.sketch

# Evita accidentalmente subir archivos grandes

#siempre subir
!public/
!Dockerfile
!nginx.conf
!.env.example
!package.json
!package-lock.json
!vite.config.js
!tailwind.config.js
!.gitignore
!README.md
!entrypoint.sh
public/env.js
!index.html
!eslint.config.js
!vite.config.js
!tailwind.config.js
!postcss.config.js

# No borres este archivo. Protege tu código, secretos y espacio en el repo.
