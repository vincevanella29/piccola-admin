# Club della Nonna Frontend - Ejemplo de archivo .env
# Copia este archivo como ".env" y completa los valores reales para tu entorno

# Web3Auth Client ID (frontend auth)
VITE_WEB3AUTH_CLIENT_ID=tu-web3auth-client-id

# API URLs
VITE_API_URL=https://api.tusitio.com/api
VITE_API_URL_DEV=http://localhost:5173/api

# RPC URLs para Polygon Amoy/Testnet
VITE_RPC_URL=https://rpc-amoy.polygon.technology/
VITE_RPC_URL2=https://polygon-amoy.infura.io/v3/tu-infura-key

# Red blockchain (mainnet, sapphire_devnet, etc)
VITE_NETWORK=mainnet

# Privy App ID (Web3 login)
VITE_PRIVY_APP_ID=tu-privy-app-id

# Explorador de bloques
VITE_BLOCK_EXPLORER=https://polygonscan.com

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key
VITE_GOOGLE_MAP_ID=tu-google-map-id

# Chain ID (Polygon Amoy: 80002, Mainnet: 137)
VITE_CHAIN_ID=137

# Modo de entorno (PROD/DEV)
VITE_MODE=PROD
VITE_DEV=false

# VAPID Key para notificaciones push
VITE_VAPID_KEY=tu-vapid-key

# Company ID (para multi-tenancy)
VITE_COMPANY_ID=tu-company-id

# DRIP (marketing/segmentación)
VITE_DRIP_ACCOUNT_ID=tu-drip-account-id
VITE_DRIP_API_KEY=tu-drip-api-key
VITE_DRIP_USER_AGENT=tu-drip-user-agent

# NOTA: No subas tu archivo .env real al repositorio. Mantén este ejemplo para referencia y onboarding.
