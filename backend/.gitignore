# Vanellix Hub Backend - .gitignore profesional

# Entornos virtuales
venv/
.env
test-vpn/
static/

# Archivos temporales y cachés
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.log
*.sqlite3
*.db
*.pid
*.swp
.DS_Store

# Configuración de IDEs y editores
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Archivos de pruebas y cobertura
test-results/
.coverage
htmlcov/

# Archivos de despliegue y builds
*.egg-info/
dist/
build/

# Otros archivos sensibles o de usuario
*.pem
*.key
*.crt
*.bak
*.old
*.orig
*.ovpn

# Node (por si hay scripts JS)
node_modules/
utils/mtz.ovpn

# MongoDB dumps/backups
*.bson
*.json
*.archive

!config/trackers/events_catalog.json

# Evita accidentalmente subir archivos grandes
*.zip
*.tar.gz
*.tgz
*.7z
*.rar

# Documentación generada
docs/_build/

# Subgraph
subgraph_vanellix/

#no obviar esto
!.env.example
!Dockerfile
!contracts/
!contracts/**/
!contracts/**/*.json
!contracts/**/*.dbg.json
!contracts/**/*.sol

# ¡Nunca borres este .gitignore! Protege tu código y credenciales.
