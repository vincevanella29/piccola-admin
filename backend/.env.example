# Club della Nonna Backend - Ejemplo de archivo .env
# Copia este archivo como ".env" y completa los valores reales para tu entorno

# Claves de seguridad
SECRET_KEY=tu-secret-key
ENCRYPTION_KEY=tu-encryption-key
PRIVATE_KEY_WALLET=tu-private-key-wallet
TOKEN_CONTRACT_ADDRESS=tu-token-contract-address

# Base de datos
MONGODB_URI=mongodb://localhost:27017

# Blockchain Providers
WEB3_PROVIDER_URL=https://rpc-amoy.polygon.technology
WEB3_PROVIDER_URL2=https://polygon-amoy.infura.io/v3/tu-infura-key
CHAIN_ID=80002

# Web3Auth y Privy
WEB3AUTH_CLIENT_ID=tu-web3auth-client-id
WEB3AUTH_CLIENT_SECRET=tu-web3auth-client-secret
PRIVY_JWT_PUBLIC_KEY="tu-public-key"
PRIVY_APP_ID=tu-privy-app-id
PRIVY_API_SECRET=tu-privy-api-secret

# IPFS/Storage
WEB3STORAGE_TOKEN=tu-web3storage-token
PINATA_API_KEY=tu-pinata-api-key
PINATA_API_SECRET=tu-pinata-api-secret
PINATA_JWT=tu-pinata-jwt

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE=blockchain_events

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=tu-r2-access-key-id
R2_SECRET_ACCESS_KEY=tu-r2-secret-access-key
R2_BUCKET_NAME=tu-r2-bucket-name
R2_ENDPOINT_URL=https://xxxxxx.r2.cloudflarestorage.com
R2_CDN_BASE=https://cdn.tusitio.com

# Company ID (contratos Vanellix HUB)
COMPANY_ID=tu-company-id

# DRIP (marketing/segmentación)
DRIP_ACCOUNT_ID=tu-drip-account-id
DRIP_API_KEY=tu-drip-api-key
DRIP_USER_AGENT=tu-drip-user-agent

# VPN (si aplica)
VPN_USER=tu-vpn-user
VPN_PASS=tu-vpn-pass

# Integración Tienda Piccola
PICCOLA_API_TOKEN=tu-piccola-api-token
URL_PICCOLA=https://tienda.tusitio.com

# Integración DMenu5
DMENU5_API_TOKEN=tu-dmenu5-api-token
URL_DMENU5=https://dmenu5.tusitio.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu-telegram-bot-token

# xAI (Grok)
XAI_API_KEY=tu-xai-api-key
# opcionales, defaults en el código
XAI_API_URL=https://api.x.ai/v1/chat/completions
XAI_MODEL=grok-2-latest

# NOTA: No subas tu archivo .env real al repositorio. Mantén este ejemplo para referencia y onboarding.
